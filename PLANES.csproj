<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.3" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.3" PrivateAssets="all" />
  </ItemGroup>

  <!-- Excluir la carpeta del subproyecto PLANES_DE_AHORRO para no compilarla dos veces -->
  <ItemGroup>
    <Compile Remove="PLANES_DE_AHORRO\**" />
    <Content Remove="PLANES_DE_AHORRO\**" />
    <EmbeddedResource Remove="PLANES_DE_AHORRO\**" />
    <None Remove="PLANES_DE_AHORRO\**" />
  </ItemGroup>

</Project>
