@* Formulario de contacto: única responsabilidad de recolección y envío de datos (SOLID - S). *@
@inject IPlanesConfig Config
@inject IJSRuntime JS

<section class="csj-contact" id="contacto" aria-labelledby="contact-form-title">
    <div class="csj-contact__inner">
        <h2 id="contact-form-title" class="csj-contact__title">
            O dejanos tus datos y te contactamos:
        </h2>
        <EditForm Model="@_model" FormName="contacto">
            <div class="csj-form">
                <label class="csj-form__label" for="nombre">Nombre</label>
                <InputText id="nombre"
                           @bind-Value="_model.Nombre"
                           class="@NombreInputClass"
                           placeholder="Nombre" />

                <label class="csj-form__label" for="localidad">Localidad</label>
                <InputText id="localidad"
                           @bind-Value="_model.Localidad"
                           class="@LocalidadInputClass"
                           placeholder="Localidad" />

                <label class="csj-form__label" for="domicilio">Domicilio</label>
                <InputText id="domicilio"
                           @bind-Value="_model.Domicilio"
                           class="csj-form__input"
                           placeholder="Domicilio" />

                <label class="csj-form__label" for="celular">Celular</label>
                <InputText id="celular"
                           @bind-Value="_model.Celular"
                           class="@CelularInputClass"
                           placeholder="3751-418382"
                           maxlength="11" />

                <label class="csj-form__label" for="observaciones">Observaciones Adicionales <span class="csj-form__hint">(hasta 100 caracteres)</span></label>
                <InputTextArea id="observaciones"
                              @bind-Value="_model.ObservacionesAdicionales"
                              class="csj-form__input csj-form__textarea"
                              placeholder="Observaciones Adicionales"
                              maxlength="100"
                              rows="3" />

                <a href="@GetHrefSegunValidacion()"
                   class="csj-btn"
                   target="_blank"
                   rel="noopener noreferrer"
                   @onclick="AlHacerClicEnviar"
                   @onclick:preventDefault="@(!FormularioValido())">
                    ENVIAR
                </a>
            </div>
        </EditForm>
        <p class="csj-contact__disclaimer">
            Al enviar aceptás que te contactemos por los medios indicados. Tus datos no serán compartidos con terceros.
        </p>
    </div>
</section>

@code {
    private ContactoModel _model = new();
    private bool _errorsNombre, _errorsLocalidad, _errorsCelular;

    private string NombreInputClass => "csj-form__input" + (_errorsNombre ? " invalid" : "");
    private string LocalidadInputClass => "csj-form__input" + (_errorsLocalidad ? " invalid" : "");
    private string CelularInputClass => "csj-form__input" + (_errorsCelular ? " invalid" : "");

    private bool FormularioValido()
    {
        try
        {
            return _model != null
                && !string.IsNullOrWhiteSpace(_model.Nombre)
                && !string.IsNullOrWhiteSpace(_model.Localidad)
                && _model.CelularSoloDigitos?.Length == ContactoModel.CelularDigitsLength;
        }
        catch (Exception ex)
        {
            _ = Log("FormularioValido ERROR", ex.Message);
            return false;
        }
    }

    private string GetHrefSegunValidacion()
    {
        try
        {
            return FormularioValido() ? GetWhatsAppHref() : "javascript:void(0)";
        }
        catch (Exception ex)
        {
            _ = Log("GetHrefSegunValidacion ERROR", ex.Message);
            return "javascript:void(0)";
        }
    }

    private string GetWhatsAppHref()
    {
        var n = _model?.Nombre?.Trim() ?? "";
        var l = _model?.Localidad?.Trim() ?? "";
        var d = _model?.Domicilio?.Trim() ?? "";
        var c = _model?.Celular ?? "";
        var o = _model?.ObservacionesAdicionalesTrimmed ?? "";
        var mensaje = "HOLA, VENGO DE LA PAGINA Y ESTOY INTERESADO EN LOS PLANES DE CAPITALIZACIÓN Y AHORRO, MIS DATOS SON:"
            + $"\nNombre: {n}"
            + $"\nLocalidad: {l}"
            + $"\nDomicilio: {d}"
            + $"\nCelular: {c}"
            + (string.IsNullOrEmpty(o) ? "" : $"\nObservaciones: {o}");
        return WhatsAppHelper.BuildUrl(Config.WhatsappPlansPhone, mensaje);
    }

    private async Task Log(string tag, string mensaje)
    {
        try
        {
            await JS.InvokeVoidAsync("console.log", $"[ContactForm] {tag}: {mensaje}");
        }
        catch { /* ignorar si la consola no está disponible */ }
    }

    private async Task AlHacerClicEnviar()
    {
        try
        {
            await Log("AlHacerClicEnviar", $"Nombre='{_model?.Nombre ?? ""}', Localidad='{_model?.Localidad ?? ""}', Domicilio='{_model?.Domicilio ?? ""}', Celular='{_model?.Celular ?? ""}', Observaciones='{_model?.ObservacionesAdicionalesTrimmed ?? ""}'");
            if (FormularioValido())
            {
                await Log("AlHacerClicEnviar", "Válido -> se abre WhatsApp");
                return;
            }
            _errorsNombre = string.IsNullOrWhiteSpace(_model?.Nombre);
            _errorsLocalidad = string.IsNullOrWhiteSpace(_model?.Localidad);
            _errorsCelular = _model?.CelularSoloDigitos?.Length != ContactoModel.CelularDigitsLength;
            await Log("AlHacerClicEnviar", $"Errores: Nombre={_errorsNombre}, Localidad={_errorsLocalidad}, Celular={_errorsCelular}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await Log("AlHacerClicEnviar ERROR", ex.Message + " | " + ex.StackTrace);
            throw;
        }
    }

    private class ContactoModel
    {
        public const int MaxObservacionesLength = 100;
        public const int CelularDigitsLength = 10;

        private string _nombre = "";
        private string _localidad = "";
        private string _celularDigits = "";

        public string Nombre
        {
            get => _nombre;
            set => _nombre = SoloTexto(value ?? "");
        }

        public string Localidad
        {
            get => _localidad;
            set => _localidad = SoloTexto(value ?? "");
        }

        public string Domicilio { get; set; } = "";

        public string Celular
        {
            get => FormatearCelular(_celularDigits);
            set => _celularDigits = SoloDigitos(value ?? "").Length > CelularDigitsLength
                ? SoloDigitos(value).Substring(0, CelularDigitsLength)
                : SoloDigitos(value ?? "");
        }

        public string CelularSoloDigitos => _celularDigits;

        private string _observacionesAdicionales = "";

        public string ObservacionesAdicionales
        {
            get => _observacionesAdicionales;
            set => _observacionesAdicionales = value?.Length > MaxObservacionesLength
                ? value.Substring(0, MaxObservacionesLength)
                : (value ?? "");
        }

        public string ObservacionesAdicionalesTrimmed => ObservacionesAdicionales?.Trim() ?? "";

        private static string SoloTexto(string value)
        {
            if (string.IsNullOrEmpty(value)) return "";
            return new string(value.Where(c => char.IsLetter(c) || c == ' ' || c == '\'' || c == '-').ToArray());
        }

        private static string SoloDigitos(string value)
        {
            if (string.IsNullOrEmpty(value)) return "";
            return new string(value.Where(char.IsDigit).ToArray());
        }

        private static string FormatearCelular(string digitos)
        {
            if (string.IsNullOrEmpty(digitos)) return "";
            if (digitos.Length <= 4) return digitos;
            return digitos.Substring(0, 4) + "-" + digitos.Substring(4);
        }
    }
}
