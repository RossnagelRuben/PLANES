@* Hero: mensaje principal y CTA WhatsApp (SOLID - S). Depende de IPlanesConfig para el número. *@
@inject IPlanesConfig Config

<section class="csj-hero" aria-labelledby="hero-mensaje">
    <div class="csj-hero__content">
        <div id="hero-mensaje" class="csj-hero__mensaje" role="heading" aria-level="1">
            ¡Suscribite a nuestros planes de capitalización y ahorro!
        </div>
        <a href="@WhatsAppHelper.BuildUrl(Config.WhatsappPlansPhone, "Hola, vengo de la pagina, quiero saber mas sobre los planes de capitalizacion y ahorro")"
           class="csj-btn csj-btn--whatsapp"
           target="_blank"
           rel="noopener noreferrer">
            <span class="csj-btn__icon" aria-hidden="true"></span>
            HABLÁ CON NOSOTROS AHORA MISMO
        </a>
    </div>
    <div class="csj-hero__image-wrap">
        <div class="csj-hero__images-box">
            <img src="https://www.clubsanjorge.com.ar/sites/default/files/2022-01/Logo%20Club%20San%20Jorge%20con%20slogan%20color.png"
                 alt="Club San Jorge - Logo con slogan"
                 class="csj-hero__image"
                 width="400"
                 height="300"
                 loading="eager" />
        </div>
    </div>
</section>
